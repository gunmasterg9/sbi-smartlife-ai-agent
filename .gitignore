# Dependencies
/frontend/node_modules/
/backend/.venv/

# Next.js build output
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/.pnp
/frontend/.pnp.*
/frontend/.yarn/*
/frontend/next-env.d.ts
/frontend/*.tsbuildinfo

# Python cache & logs
__pycache__/
*.py[cod]
*$py.class
/backend/__pycache__/
/backend/app/__pycache__/
/backend/app/agents/__pycache__/
/backend/app/api/__pycache__/
/backend/app/api/v1/__pycache__/
/backend/app/middleware/__pycache__/
/backend/app/models/__pycache__/
/backend/app/schemas/__pycache__/
/backend/app/rag/__pycache__/
/backend/seeds/__pycache__/

# Local environment files (containing keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
/frontend/.env*.local
/backend/.env

# Large database files (optional: keep if needed for instant setup, but best ignored)
# We will track the SQLite database for easy cloning/testing since it is pre-seeded for the hackathon demo,
# unless you prefer otherwise.

# OS & Logs
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
