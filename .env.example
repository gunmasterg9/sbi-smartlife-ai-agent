# ============================================
# SBI SmartLife AI Agent - Environment Variables
# ============================================

# Application
APP_NAME=SBI SmartLife AI Agent
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://sbi_user:sbi_password@localhost:5432/sbi_smartlife
DATABASE_SYNC_URL=postgresql://sbi_user:sbi_password@localhost:5432/sbi_smartlife

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Configuration
AI_MODE=simulated
# AI_MODE=live  # Uncomment for real LLM integration
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
AI_MODEL=gemini-2.5-flash

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
